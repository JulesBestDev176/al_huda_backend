# MongoDB (Docker local)
MONGODB_URI=mongodb://admin:hadith2024@localhost:27018/hadith_db?authSource=admin

# Identifiants Docker (utilisés par docker-compose.yml)
MONGO_USER=admin
MONGO_PASSWORD=hadith2024
ME_USER=admin
ME_PASSWORD=admin123

# Qdrant (vector search)
# En développement local avec Docker :
QDRANT_URL=http://localhost:6333
# En production (conteneur Docker) : http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hadiths

# Redis
# En développement local avec Docker :
REDIS_URL=redis://localhost:6380

# Embedding (HuggingFace Inference API)
HUGGINGFACE_API_KEY=hf_your_key_here
EMBEDDING_MODEL=intfloat/multilingual-e5-large
SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_your_groq_key_here   # Gratuit sur console.groq.com

# App
PORT=4000
NODE_ENV=development

# Scraper
SCRAPER_DELAY_MS=1500
SCRAPER_CONCURRENCY=2
