{
  "name": "hadith-backend",
  "version": "1.0.0",
  "description": "Backend NestJS pour la plateforme Hadith Sénégal",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "seed:all": "ts-node -r dotenv/config scripts/seed-forum.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "scrape": "ts-node -r dotenv/config scripts/scrape-to-db.ts",
    "scrape:bukhari": "ts-node -r dotenv/config scripts/scrape-to-db.ts bukhari",
    "scrape:narrators": "ts-node -r dotenv/config scripts/scrape-narrators.ts",
    "embeddings": "ts-node -r dotenv/config scripts/run-embeddings.ts",
    "backfill:isnad": "ts-node -r dotenv/config scripts/backfill-isnad.ts",
    "seed:forum": "ts-node -r dotenv/config scripts/seed-forum.ts",
    "clean:forum-rejected": "ts-node -r dotenv/config scripts/clean-forum-rejected-answers.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "mongoose": "^8.0.0",
    "p-limit": "^3.1.0",
    "p-retry": "^5.1.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
